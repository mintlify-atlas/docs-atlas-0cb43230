  "keyFeatures": [
    "Anthropic-compatible API proxy to Antigravity Cloud Code",
    "Multi-account load balancing with sticky, round-robin, and hybrid strategies",
    "Support for Claude (Opus, Sonnet, Haiku) and Gemini models",
    "Intelligent quota management and automatic account switching",
    "Web management dashboard with real-time monitoring",
    "Prompt caching support for improved performance",
    "Model fallback on quota exhaustion",
    "CLI tool for account management and server control"
  ],
  "publicApiSurface": [
    "POST /v1/messages - Send messages to Claude/Gemini models",
    "GET /v1/models - List available models",
    "GET /health - Server health check",
    "GET /account-limits - Account quota and subscription info",
    "acc start - Start proxy server",
    "acc stop - Stop proxy server",
    "acc accounts add - Add Google account via OAuth",
    "acc ui - Open web dashboard"
  ]
